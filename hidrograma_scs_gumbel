#' Ajusta distribuição de Gumbel (método dos momentos) e calcula chuvas de projeto.
#'
#' @param serie_maximas Vetor numérico com máximas anuais (mm)
#' @param trs           Vetor de tempos de retorno (anos)
#' @return Data frame com TR, probabilidade e chuva de projeto (mm)
calcular_gumbel <- function(serie_maximas, trs) {
  
  media  <- mean(serie_maximas)
  desvio <- sd(serie_maximas)
  n      <- length(serie_maximas)
  
  # Parâmetros de Gumbel — Ajuste por Momentos
  alpha <- (sqrt(6) * desvio) / pi
  beta  <- media - 0.5772 * alpha    # 0.5772 ≈ constante de Euler-Mascheroni
  
  message(sprintf(
    "Gumbel ajustado: n=%d anos | média=%.1f mm | α=%.4f | β=%.4f",
    n, media, alpha, beta
  ))
  
  data.frame(TR = trs) %>%
    mutate(
      Prob_Nao_Excedencia = 1 - (1 / TR),
      P_dia_mm = beta - alpha * log(-log(Prob_Nao_Excedencia))
    )
}

