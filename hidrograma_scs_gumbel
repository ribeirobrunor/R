#' Obtém as máximas anuais de precipitação diária de uma estação da ANA.
#'
#' @param cod_estacao  Código da estação (character ou numeric)
#' @param nivel_cons   Nível de consistência: 1 = bruto, 2 = consistido
#' @return Data frame com colunas: Ano, P_max_anual (mm)
obter_maximas_ana <- function(cod_estacao, nivel_cons = 2) {
  
  url_base <- "http://telemetriaws1.ana.gov.br/ServiceANA.asmx/HidroSerieHistorica"
  
  resp <- GET(url_base, query = list(
    codEstacao        = as.character(cod_estacao),
    dataInicio        = "",
    dataFim           = "",
    tipoDados         = "2",           # 2 = Pluviométrico
    nivelConsistencia = nivel_cons
  ))
  
  if (http_error(resp)) {
    warning(paste("Erro HTTP para estação:", cod_estacao))
    return(NULL)
  }
  
  xml_root <- read_xml(content(resp, "text", encoding = "UTF-8"))
  series   <- xml_find_all(xml_root, ".//SerieHistorica")
  
  if (length(series) == 0) {
    warning(paste("Nenhuma série encontrada para estação:", cod_estacao))
    return(NULL)
  }
  
  # --- CORREÇÃO PRINCIPAL: composição correta das datas diárias ---------------
  # O WebService retorna um registro por mês. 'DataHora' contém o mês de
  # referência (ex: "2005-01-01T00:00:00"). Os valores Chuva01 a Chuva31
  # correspondem aos dias 1 a 31 daquele mês.
  
  df_list <- map(series, function(node) {
    
    data_ref_str <- xml_text(xml_find_first(node, ".//DataHora"))
    data_ref     <- as.Date(substr(data_ref_str, 1, 10))  # "YYYY-MM-DD"
    
    map_dfr(1:31, function(i) {
      tag <- paste0(".//Chuva", sprintf("%02d", i))
      val <- suppressWarnings(
        as.numeric(xml_text(xml_find_first(node, tag)))
      )
      
      # Compõe a data real do dia i dentro do mês de referência
      data_dia <- tryCatch({
        # Substitui o dia na data de referência
        as.Date(paste0(
          format(data_ref, "%Y-%m-"),
          sprintf("%02d", i)
        ))
      }, error = function(e) NA_Date_)
      
      # Rejeita datas inválidas (ex: dia 31 em fevereiro)
      if (is.na(data_dia) || format(data_dia, "%m") != format(data_ref, "%m")) {
        return(NULL)
      }
      
      data.frame(Data = data_dia, Chuva_Diaria = val)
    })
  })
  
  # --- Agrupamento anual e extração da máxima ----------------------------------
  df_final <- bind_rows(df_list) %>%
    filter(!is.na(Chuva_Diaria), Chuva_Diaria >= 0) %>%
    mutate(Ano = year(Data)) %>%
    group_by(Ano) %>%
    summarise(P_max_anual = max(Chuva_Diaria, na.rm = TRUE), .groups = "drop") %>%
    filter(is.finite(P_max_anual))
  
  return(df_final)
}

