# --- DEFINIÇÕES DO USUÁRIO ----------------------------------------------------
area_km2                <- 0.862       # Área da bacia (km²)
comprimento_talvegue_m  <- 1692.21     # Comprimento do talvegue (m)
declividade_m_m         <- 0.0004      # Declividade média (m/m)
CN                      <- 77          # Curve Number
p                       <- 0.475       # Fração de cobertura vegetal (0 a 1)

# --- 4.1 Tempo de Concentração ------------------------------------------------
# Tc (min) = 16 * L (km) / [(1.05 - 0.2p) * (100*S)^0.04] (George Ribeiro)
# Tc (min) = 3.989 * ( L (km)^0.77 * S (m/s)^(-0.385)) (Kirpich)
# ajuste a linha abaixo e documente a fonte.

tc_min <- 3.989*(((comprimento_talvegue_m/1000)^0.77)*declividade_m_m^(-0.385))

tc_h   <- tc_min / 60   # Tc em horas

message(sprintf("Tc = %.2f min = %.4f h", tc_min, tc_h))

# --- 4.2 Parâmetros do Hidrograma Unitário SCS --------------------------------
# Duração da chuva unitária recomendada: delta_t ≤ 0.2 * Tc (SCS, 1972)
delta_t_h <- (tc_min / 5) / 60        # duração unitária em horas

# Tempo de retardo: tl = 0.6 * Tc  (SCS)
t_lag_h   <- 0.6 * tc_h

# Tempo de pico: Tp = delta_t/2 + tl
t_pico_h  <- (delta_t_h / 2) + t_lag_h

# Vazão de pico unitária (m³/s por mm de chuva excedente)
q_pico_unit <- (0.208 * area_km2) / t_pico_h

message(sprintf(
  "delta_t=%.4f h | t_lag=%.4f h | Tp=%.4f h | qp_unit=%.4f m³/s/mm",
  delta_t_h, t_lag_h, t_pico_h, q_pico_unit
))

# ==============================================================================
# SEÇÃO 5 — CHUVA EXCEDENTE (MÉTODO CN)
# ==============================================================================

# Potencial máximo de retenção (mm)
S <- (25400 / CN) - 254

#' Calcula a chuva excedente (Pe) pelo método SCS-CN.
#'
#' @param P_total  Chuva de projeto diária (mm)
#' @return         Pe em mm (chuva excedente)
calc_pe <- function(P_total) {
  # Correção DNOS/CETESB: P_24h ≈ 1,14 * P_dia
  # Relação entre chuva de 24 horas e chuva diária (leituras às 7h)
  P_24h <- P_total * 1.14
  
  Ia <- 0.2 * S   # Abstração inicial
  
  if (P_24h > Ia) {
    Pe <- ((P_24h - Ia)^2) / (P_24h + 0.8 * S)
  } else {
    Pe <- 0
  }
  return(Pe)
}

