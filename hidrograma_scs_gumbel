#' Gera o hidrograma de projeto para um dado TR.
#'
#' @param P_dia      Chuva de projeto diária (mm) para o TR
#' @param tr         Tempo de retorno (anos) — usado só para rotular
#' @param q_unit     Vazão de pico unitária (m³/s/mm)
#' @param Tp         Tempo de pico (h)
#' @param adim       Data frame do hidrograma adimensional SCS
#' @return Data frame com t_h, Q_m3s, TR
gerar_hidrograma <- function(P_dia, tr, q_unit, Tp, adim) {
  Pe <- calc_pe(P_dia)
  
  Qp <- q_unit * Pe   # Vazão de pico real (m³/s)
  
  adim %>%
    mutate(
      t_h   = t_Tp * Tp,
      Q_m3s = q_qp * Qp,
      TR    = paste0("TR ", tr, " anos"),
      Pe_mm = round(Pe, 2),
      Qp_m3s = round(Qp, 4)
    )
}

