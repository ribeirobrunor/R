# SEÇÃO 7 — MÁXIMA ANUAL PONDERADA POR THIESSEN
# ==============================================================================

#' Pondera as máximas anuais de cada estação pelo peso de Thiessen.
#' Apenas anos com dados em TODAS as estações são usados (ano completo).
#' Anos parciais são ponderados pela soma dos pesos disponíveis (normalizada).
#' @param series_lista Lista de data frames por estação
#' @param pesos        data frame com codigo e peso_thiessen
#' @return data frame: Ano, P_max_ponderada
calcular_serie_ponderada <- function(series_lista, pesos) {

  # Filtra pesos para apenas estações com dados
  pesos_disp <- pesos %>%
    filter(codigo %in% names(series_lista)) %>%
    mutate(peso_thiessen = peso_thiessen / sum(peso_thiessen))  # renormaliza

  # Empilha todas as séries
  df_all <- bind_rows(series_lista) %>%
    inner_join(pesos_disp, by = "codigo")

  # Ponderação ano a ano (aceita anos parciais com renormalização)
  df_pond <- df_all %>%
    group_by(Ano) %>%
    mutate(soma_pesos = sum(peso_thiessen)) %>%
    summarise(
      P_max_ponderada = sum(P_max_anual * peso_thiessen) / first(soma_pesos),
      n_estacoes      = n(),
      .groups         = "drop"
    ) %>%
    filter(is.finite(P_max_ponderada))

  return(df_pond)
}

