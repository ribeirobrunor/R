#' Baixa o inventário completo de estações pluviométricas da ANA.
#' Endpoint: HidroInventario
#' @return sf com geometria de pontos (WGS84 → UTM 31983)
obter_inventario_ana <- function() {

  url <- "http://telemetriaws1.ana.gov.br/ServiceANA.asmx/HidroInventario"

  resp <- GET(url, query = list(
    codEstDE       = "",
    codEstATE      = "",
    tpEst          = "2",   # 2 = Pluviométrica
    nmEst          = "",
    nmRio          = "",
    codSubBacia    = "",
    codBacia       = "",
    nmMunicipio    = "",
    nmEstado       = "",
    sgResp         = "",
    sgOper         = "",
    telemetrica    = ""
  ), timeout(60))

  if (http_error(resp)) stop("Falha ao acessar HidroInventario da ANA.")

  xml_root  <- read_xml(content(resp, "text", encoding = "UTF-8"))
  estacoes  <- xml_find_all(xml_root, ".//Table")

  message("Total de estações pluviométricas no inventário: ", length(estacoes))

  df <- map_dfr(estacoes, function(node) {
    get_val <- function(tag) {
      v <- xml_text(xml_find_first(node, paste0(".//", tag)))
      if (is.na(v) || v == "") NA_character_ else trimws(v)
    }
    data.frame(
      codigo    = get_val("Codigo"),
      nome      = get_val("Nome"),
      lat       = suppressWarnings(as.numeric(get_val("Latitude"))),
      lon       = suppressWarnings(as.numeric(get_val("Longitude"))),
      municipio = get_val("nmMunicipio"),
      estado    = get_val("sgUF"),
      resp      = get_val("ResponsavelSigla"),
      stringsAsFactors = FALSE
    )
  }) %>%
    filter(!is.na(lat), !is.na(lon))

  # Converte para sf (WGS84) e depois UTM 31983 para compatibilidade espacial
  sf_est <- st_as_sf(df, coords = c("lon", "lat"), crs = 4326) %>%
    st_transform(31983)

  return(sf_est)
}

# ==============================================================================
# SEÇÃO 4 — FILTRO ESPACIAL COM EXPANSÃO AUTOMÁTICA DE BUFFER
# ==============================================================================

message("\nBaixando inventário de estações da ANA...")
inventario <- obter_inventario_ana()

#' Filtra estações dentro de um buffer e expande se necessário.
#' @param bacia_utm  sf da bacia reprojetada
#' @param inventario sf do inventário ANA
#' @param dist_ini   Buffer inicial (m)
#' @param dist_max   Buffer máximo (m)
#' @param step       Incremento de expansão (m)
#' @return lista com: estacoes_sf, buffer_final_sf, dist_final
selecionar_estacoes <- function(bacia_utm, inventario,
                                dist_ini, dist_max, step) {
  dist_atual <- dist_ini

  repeat {
    buffer_atual <- st_buffer(bacia_utm, dist_atual)
    dentro       <- st_filter(inventario, buffer_atual)

    if (nrow(dentro) > 0) {
      message(sprintf(
        ">> %d estação(ões) encontrada(s) com buffer de %.0f m.",
        nrow(dentro), dist_atual
      ))
      return(list(
        estacoes   = dentro,
        buffer     = buffer_atual,
        dist_final = dist_atual
      ))
    }

    if (dist_atual >= dist_max) {
      stop(sprintf(
        "Nenhuma estação encontrada mesmo com buffer de %.0f m. Verifique o shapefile ou aumente dist_buffer_max.",
        dist_max
      ))
    }

    dist_atual <- dist_atual + step
    message(sprintf(
      "Nenhuma estação no buffer de %.0f m — expandindo para %.0f m...",
      dist_atual - step, dist_atual
    ))
  }
}

