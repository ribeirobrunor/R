# --- 11.3 Polígonos de Thiessen sobre o buffer ------------------------------
# Reconstrói Voronoi para plotagem

envelope_plot  <- st_buffer(buffer_sf, dist = as.numeric(st_area(buffer_sf))^0.5)
voronoi_plot   <- st_voronoi(st_union(estacoes_sf), envelope = st_geometry(envelope_plot))
voronoi_pol_pl <- st_collection_extract(voronoi_plot, "POLYGON") %>%
  st_sf() %>% st_set_crs(st_crs(estacoes_sf))
voronoi_clip_pl <- st_intersection(voronoi_pol_pl, buffer_sf)

idx_near <- st_nearest_feature(voronoi_clip_pl, estacoes_sf)
voronoi_clip_pl$codigo <- estacoes_sf$codigo[idx_near]
voronoi_clip_pl <- voronoi_clip_pl %>%
  left_join(pesos_thiessen, by = "codigo")

coords_est <- estacoes_sf %>%
  mutate(x = st_coordinates(.)[, 1], y = st_coordinates(.)[, 2]) %>%
  st_drop_geometry() %>%
  left_join(pesos_thiessen, by = "codigo")

p_mapa <- ggplot() +
  geom_sf(data = voronoi_clip_pl, aes(fill = peso_thiessen),
          color = "white", linewidth = 0.6, alpha = 0.75) +
  geom_sf(data = bacia_utm, fill = NA, color = "#1565C0", linewidth = 1.2) +
  geom_point(data = coords_est, aes(x = x, y = y),
             shape = 24, fill = "#F44336", color = "white",
             size = 3, stroke = 0.8) +
  geom_label(data = coords_est,
             aes(x = x, y = y,
                 label = paste0(codigo, "\n", round(peso_thiessen * 100, 1), "%")),
             size = 2.5, label.size = 0.2,
             nudge_y = dist_final_m * 0.06, fontface = "bold") +
  scale_fill_distiller(palette = "Blues", direction = 1,
                       labels = percent_format(accuracy = 1),
                       name = "Peso\nThiessen") +
  labs(
    title    = "Polígonos de Thiessen — pesos por estação",
    subtitle = paste0("Buffer de busca: ", dist_final_m / 1000, " km"),
    caption  = "Azul: bacia hidrográfica | Triângulo vermelho: estação pluviométrica"
  ) +
  theme_minimal(base_size = 11) +
  theme(
    plot.title    = element_text(face = "bold", size = 12),
    plot.subtitle = element_text(size = 9, color = "gray45"),
    plot.caption  = element_text(size = 8, color = "gray50"),
    axis.title    = element_blank(),
    axis.text     = element_text(size = 8),
    legend.position = "right",
    plot.background  = element_rect(fill = "white", color = NA),
    panel.background = element_rect(fill = "white", color = NA)
  )

# --- 11.4 Barras Pe vs Abstração --------------------------------------------
p_pe <- tabela_final %>%
  mutate(
    Abstr      = P_24h - Pe_mm,
    TR_label   = paste0("TR ", TR, " anos")
  ) %>%
  pivot_longer(cols = c(Pe_mm, Abstr),
               names_to = "componente", values_to = "mm") %>%
  mutate(componente = recode(componente,
                             Pe_mm = "Chuva excedente (Pe)",
                             Abstr = "Abstração + Infiltração")) %>%
  ggplot(aes(x = TR_label, y = mm, fill = componente)) +
  geom_col(width = 0.55) +
  geom_text(
    data = tabela_final %>%
      mutate(TR_label = paste0("TR ", TR, " anos")),
    aes(x = TR_label, y = P_24h, label = paste0("Pe=", round(Pe_mm, 1), " mm")),
    inherit.aes = FALSE, vjust = -0.4, size = 3, fontface = "bold"
  ) +
  scale_fill_manual(values = c(
    "Chuva excedente (Pe)"    = "#EF5350",
    "Abstração + Infiltração" = "#90A4AE"
  )) +
  labs(
    title   = "Decomposição P₂₄ₕ por TR",
    x       = NULL, y = "Lâmina (mm)", fill = NULL,
    caption = paste0("CN=", CN, " | S=", round(S,1), " mm | Ia=", round(0.2*S,1), " mm")
  ) +
  tema_base + theme(panel.grid.major.x = element_blank())

# --- 11.5 Composição final --------------------------------------------------
painel_final <- (p_hid) /
  (p_mapa | p_gumbel | p_pe) +
  plot_annotation(
    title    = "ANÁLISE HIDROLÓGICA — BACIA DO VALÃO DO CHINA",
    subtitle = paste0(
      "Seropédica, RJ  |  Estações selecionadas automaticamente via HidroInventário (ANA)",
      "  |  Ponderação: Thiessen  |  Gumbel (Momentos)  |  HU SCS"
    ),
    caption  = paste0(
      "Estações: ", paste(codigos_com_dados, collapse = ", "),
      "  |  Buffer final: ", dist_final_m / 1000, " km",
      "  |  Série ponderada: ", nrow(serie_ponderada), " anos"
    ),
    theme = theme(
      plot.title    = element_text(face = "bold", size = 16),
      plot.subtitle = element_text(size = 9, color = "gray40"),
      plot.caption  = element_text(size = 8, color = "gray50"),
      plot.background = element_rect(fill = "white", color = NA)
    )
  )

ggsave(
  filename = "hidrograma_thiessen_automatico.png",
  plot     = painel_final,
  width    = 16, height = 11,
  dpi      = 300,
  bg       = "white"
)

