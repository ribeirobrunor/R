# ==============================================================================
# SEÇÃO 5 — PESOS DE THIESSEN (VORONOI)
# ==============================================================================

#' Calcula os pesos de Thiessen (área de Voronoi ∩ buffer / área total do buffer).
#' @param estacoes_sf  sf das estações selecionadas
#' @param buffer_sf    sf do buffer da bacia
#' @return data frame com: codigo, peso_thiessen
calcular_thiessen <- function(estacoes_sf, buffer_sf) {

  # Envelop expandido para evitar polígonos de Voronoi cortados na borda
  envelope <- st_buffer(buffer_sf, dist = as.numeric(st_area(buffer_sf))^0.5)

  # Voronoi sobre os pontos das estações
  coords_union <- st_union(estacoes_sf)
  voronoi      <- st_voronoi(coords_union, envelope = st_geometry(envelope))
  voronoi_pol  <- st_collection_extract(voronoi, "POLYGON") %>%
    st_sf() %>%
    st_set_crs(st_crs(estacoes_sf))

  # Intersecta com o buffer da bacia
  voronoi_clip <- st_intersection(voronoi_pol, buffer_sf)

  # Associa cada polígono de Voronoi à estação mais próxima
  idx_nearest  <- st_nearest_feature(voronoi_clip, estacoes_sf)
  voronoi_clip$codigo <- estacoes_sf$codigo[idx_nearest]

  area_total <- as.numeric(st_area(buffer_sf))

  pesos <- voronoi_clip %>%
    mutate(area_voronoi = as.numeric(st_area(.))) %>%
    st_drop_geometry() %>%
    group_by(codigo) %>%
    summarise(area_voronoi = sum(area_voronoi), .groups = "drop") %>%
    mutate(peso_thiessen = area_voronoi / area_total)

  # Normaliza para garantir soma = 1 (eventuais erros numéricos)
  pesos$peso_thiessen <- pesos$peso_thiessen / sum(pesos$peso_thiessen)

  return(pesos)
}

message("\nCalculando polígonos de Thiessen...")
