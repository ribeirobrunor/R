#' Obtém máximas anuais de precipitação diária para uma estação.
#' Correção aplicada: datas compostas corretamente a partir do mês de referência.
#' @param cod_estacao Código da estação (character)
#' @param nivel_cons  Nível de consistência (1 ou 2)
#' @return data frame: Ano, P_max_anual
obter_maximas_ana <- function(cod_estacao, nivel_cons = 2) {

  url_base <- "http://telemetriaws1.ana.gov.br/ServiceANA.asmx/HidroSerieHistorica"

  resp <- GET(url_base, query = list(
    codEstacao        = as.character(cod_estacao),
    dataInicio        = "",
    dataFim           = "",
    tipoDados         = "2",
    nivelConsistencia = nivel_cons
  ), timeout(60))

  if (http_error(resp)) {
    warning(paste("Erro HTTP para estação:", cod_estacao))
    return(NULL)
  }

  xml_root <- read_xml(content(resp, "text", encoding = "UTF-8"))
  series   <- xml_find_all(xml_root, ".//SerieHistorica")

  if (length(series) == 0) {
    warning(paste("Sem dados para estação:", cod_estacao))
    return(NULL)
  }

  df_list <- map(series, function(node) {
    data_ref_str <- xml_text(xml_find_first(node, ".//DataHora"))
    data_ref     <- as.Date(substr(data_ref_str, 1, 10))

    map_dfr(1:31, function(i) {
      tag <- paste0(".//Chuva", sprintf("%02d", i))
      val <- suppressWarnings(
        as.numeric(xml_text(xml_find_first(node, tag)))
      )

      # Compõe data real; rejeita dias inexistentes no mês (ex: 31/fev)
      data_dia <- tryCatch({
        d <- as.Date(paste0(format(data_ref, "%Y-%m-"), sprintf("%02d", i)))
        if (format(d, "%m") != format(data_ref, "%m")) NA_Date_ else d
      }, error = function(e) NA_Date_)

      if (is.na(data_dia)) return(NULL)
      data.frame(Data = data_dia, Chuva_Diaria = val)
    })
  })

  bind_rows(df_list) %>%
    filter(!is.na(Chuva_Diaria), Chuva_Diaria >= 0) %>%
    mutate(Ano = year(Data)) %>%
    group_by(Ano) %>%
    summarise(P_max_anual = max(Chuva_Diaria, na.rm = TRUE), .groups = "drop") %>%
    filter(is.finite(P_max_anual)) %>%
    mutate(codigo = as.character(cod_estacao))
}

